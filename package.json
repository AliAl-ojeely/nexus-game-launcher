{
  "name": "mygamelauncher",
  "version": "1.6.0",
  "description": "A sleek game launcher for managing PC titles",
  "author": "ali al-ojeely <alialojeely@gmail.com>",
  "main": "main.js",
  "productName": "Nexus Game Launcher",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist-win": "electron-builder --win",
    "dist-linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "electron-context-menu": "^3.6.1"
  },
  "build": {
    "appId": "com.nexus.launcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Nexus Launcher"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Game"
    }
  }
}